{
  "name": "@org/shop",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "projectType": "application",
    "tags": ["scope:shop"],
    "targets": {
      "build": {
        "executor": "@nx/vite:build",
        "options": {
          "outputPath": "dist/apps/shop",
          "viteConfig": "apps/shop/vite.config.ts"
        },
        "configurations": {
          "development": {
            "mode": "development"
          },
          "production": {
            "mode": "production"
          }
        }
      },
      "serve": {
        "dependsOn": ["@org/api:serve"],
        "executor": "@nx/vite:dev-server",
        "options": {
          "buildTarget": "@org/shop:build:development"
        }
      },
      "dev": {
        "dependsOn": ["@org/api:serve"]
      },
      "preview": {
        "dependsOn": ["build", "@org/api:serve"]
      }
    }
  },
  "devDependencies": {
    "@org/models": "workspace:*",
    "@org/shop-data": "workspace:*",
    "@org/shop-feature-product-detail": "workspace:*",
    "@org/shop-feature-products": "workspace:*",
    "@org/shop-shared-ui": "workspace:*"
  }
}
